---
import { t, changeLanguage } from "i18next";
import Layout from "../layouts/Layout.astro";

changeLanguage("es");
---

<Layout>
  <main>
    <!-- Hero Section -->
    <section class='relative h-auto flex items-center justify-center overflow-hidden py-8 md:py-0'>
      <div class='absolute inset-0 bg-gradient-to-br from-slate-950 to-slate-800'></div>
      <div class='absolute top-0 right-0 w-64 h-64 md:w-96 md:h-96 bg-amber-500/20 rounded-full blur-3xl'></div>
      <div class='absolute bottom-0 left-0 w-64 h-64 md:w-96 md:h-96 bg-amber-600/10 rounded-full blur-3xl'></div>
      
      <div class='relative z-10 text-center px-4 py-0 md:py-14 max-w-6xl'>
        <h1 class='text-4xl sm:text-5xl md:text-6xl lg:text-7xl font-black text-white mb-6 leading-tight'>
          ITALIAN GERMAN EXHIBITION COMPANY MÉXICO
        </h1>
        <p set:html={t('AboutIgeco.text_igeco_2')} class='text-sm sm:text-base md:text-lg text-slate-300 leading-relaxed text-justify mb-4' />
        <p set:html={t('AboutIgeco.text_igeco_3')} class='text-sm sm:text-base md:text-lg text-slate-300 leading-relaxed text-justify' />
      </div>
    </section>

    <!-- Timeline Section -->
    <section class='py-12 md:py-20 bg-white relative'>
      <div class='container mx-auto px-4'>
        <div class='text-center mb-12 md:mb-20'>
          <h2 class='text-3xl sm:text-4xl md:text-5xl font-bold text-slate-900 mb-4 uppercase'>
            {t('AboutIgeco.sub-title')}
          </h2>
        </div>

        <!-- Grid responsivo -->
        <div class='grid grid-cols-1 md:grid-cols-2 gap-8 md:gap-12'>
          <!-- Item 1: Italian Exhibition Group -->
          <div class='flex flex-col'>
            <div class='bg-gradient-to-br from-slate-50 to-slate-100 p-6 sm:p-8 rounded-2xl border border-slate-200 hover:border-amber-300 hover:shadow-xl transition-all duration-300 h-full flex flex-col'>
              <p class='text-xs sm:text-sm font-bold text-amber-600 uppercase tracking-widest mb-2'>
                {t('AboutIgeco.title')}
              </p>
              <h3 class='text-2xl sm:text-3xl font-bold text-slate-900 mb-4'>
                ITALIAN EXHIBITION GROUP
              </h3>
              <p class='text-sm sm:text-base text-slate-700 leading-relaxed mb-4 sm:mb-6 text-justify flex-grow' set:html={t('AboutIgeco.text_igeco')} />
              <img 
                src='/img/event.webp' 
                alt='Italian Exhibition Group' 
                class='w-full h-48 sm:h-64 rounded-lg object-cover mt-4 sm:mt-6' 
              />
            </div>
          </div>

          <!-- Item 2: Deutsche Messe -->
          <div class='flex flex-col'>
            <div class='bg-gradient-to-br from-slate-50 to-slate-100 p-6 sm:p-8 rounded-2xl border border-slate-200 hover:border-amber-300 hover:shadow-xl transition-all duration-300 h-full flex flex-col'>
              <p class='text-xs sm:text-sm font-bold text-amber-600 uppercase tracking-widest mb-2'>
                {t('AboutIgeco.title')}
              </p>
              <h3 class='text-2xl sm:text-3xl font-bold text-slate-900 mb-4'>
                DEUTSCHE MESSE
              </h3>
              <p class='text-sm sm:text-base text-slate-700 leading-relaxed mb-4 sm:mb-6 text-justify flex-grow' set:html={t('AboutIgeco.text_deutsche')} />
              <img 
                src='/img/deutsche-messe.webp' 
                alt='Deutsche Messe' 
                class='w-full h-48 sm:h-64 rounded-lg object-cover mt-4 sm:mt-6' 
              />
            </div>
          </div>
        </div>
      </div>
    </section>
  </main>
</Layout>

<style>
  
  /* Optimización para pantallas pequeñas */
  @media (max-width: 640px) {
    :global(body) {
      font-size: 14px;
    }
  }
</style>

