---
import i18next, { t, changeLanguage } from "i18next";
import Layout from "../layouts/Layout.astro";
import { constans_persons } from "../data/constans_persons";

changeLanguage("es");

const currentLanguage = i18next.language;
---

<Layout>
  <main class='min-h-screen'>
    <!-- Hero Section -->
    <section class='relative bg-[#06439C] py-10 px-4 overflow-hidden'>
      <!-- Decorative background elements -->
      <div class='absolute inset-0 bg-gradient-to-r from-[#06439C] via-[#355282] to-[#06439C] opacity-90'></div>
      <div class='container mx-auto text-center relative z-10'>
        <div class='mb-8'>
          <span class='inline-block bg-white/10 backdrop-blur-sm px-8 rounded-full text-xl p-2 font-semibold tracking-widest text-white border border-white/20'>
            Deutsche Messe
          </span>
        </div>
        <h1 class='text-5xl md:text-7xl font-black mb-8 leading-tight text-white drop-shadow-lg'>
          {t('AboutUs.title')}
        </h1>
        <div class='max-w-4xl mx-auto'>
          <p class='text-xl md:text-2xl leading-relaxed text-white/95 font-light' set:html={t('AboutUs.text')} />
        </div>
      </div>
    </section>

    <!-- Team Section -->
    <section class='container mx-auto px-4 py-20'>
      <div class='grid grid-cols-2 sm:grid-cols-2 lg:grid-cols-4 gap-12 max-w-6xl mx-auto'>
        {
          constans_persons.map((person) => (
            <div>
              <div class='flex justify-center mb-4'>
                <img
                  src={person.image}
                  alt={person.name}
                  class='w-32 h-32 sm:w-48 sm:h-48 md:w-48 md:h-48 rounded-full shadow-lg object-cover object-top'
                />
              </div>
              
              <div class='text-center'>
                <h3 class='text-2xl font-bold text-[#355282] mb-2'>
                  {person.name}
                </h3>
                <p class='text-gray-600 font-medium text-sm'>
                  {currentLanguage === 'en'
                    ? person.position_en
                    : person.position}
                </p>
              </div>
            </div>
          ))
        }
      </div>
    </section>
  </main>
</Layout>
